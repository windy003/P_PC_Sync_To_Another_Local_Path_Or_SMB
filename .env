# 文件同步配置
# ============================================================
# 每个同步对包含: SOURCE(源目录), DEST(目标目录), DEPTH(深度,可选), IGNORE(忽略规则,可选)
#
# DEPTH: 控制目录同步深度
#   0 = 无限制，同步所有子目录（默认值）
#   1 = 仅同步源目录下的文件，不包括子目录
#   2 = 同步源目录 + 一层子目录
#   N = 同步源目录 + (N-1) 层子目录
#
# IGNORE: 每对独立的忽略规则（逗号分隔，支持通配符）
#   会与全局 SYNC_IGNORE 合并生效
# ============================================================

SYNC_PAIR_1_SOURCE="D:\files\using\Python\P_PC_IME\pyime\pinyin_simp.dict.yaml"
SYNC_PAIR_1_DEST="\\192.168.2.56\files\myNetdisk\Other_Devices\20C_X13_Gen2\Py_IME\"
SYNC_PAIR_1_DEPTH=1
SYNC_PAIR_1_IGNORE=


SYNC_PAIR_2_SOURCE="C:\Users\92892\AppData\Roaming\Microsoft\Windows\Start Menu\Programs\Startup"
SYNC_PAIR_2_DEST="\\192.168.2.56\files\myNetdisk\Other_Devices\20C_X13_Gen2\Startup"
SYNC_PAIR_2_DEPTH=1
SYNC_PAIR_2_IGNORE=

SYNC_PAIR_3_SOURCE="C:\Users\92892\AppData\Roaming\Microsoft\Windows\Start Menu"
SYNC_PAIR_3_DEST="\\192.168.2.56\files\myNetdisk\Other_Devices\20C_X13_Gen2\StartMenu"
SYNC_PAIR_3_DEPTH=1
SYNC_PAIR_3_IGNORE=



